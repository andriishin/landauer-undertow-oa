# Normalize line endings: this is a reproducibility repository — the
# worked-example outputs must byte-match across platforms, so all text
# is stored and checked out with LF.
* text=auto eol=lf
*.png binary
*.pdf binary
*.eps binary
*.svg text eol=lf
# Windows batch files must keep CRLF or cmd.exe mis-parses them.
*.bat text eol=crlf
*.cmd text eol=crlf
